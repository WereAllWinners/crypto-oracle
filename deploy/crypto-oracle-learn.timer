[Unit]
Description=Crypto Oracle — Run learning cycle nightly at midnight UTC
Requires=crypto-oracle-learn.service

[Timer]
# Fire at midnight UTC every day
OnCalendar=*-*-* 00:00:00 UTC
# If the machine was off at midnight, run as soon as it comes back up
Persistent=true
# Random delay up to 5 minutes to avoid thundering-herd with other services
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
