# ============================================================
# Crypto Oracle — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Coinbase Advanced Trade API
# Required for: OHLCV data collection, live/paper trading
# Get yours at: https://advanced.coinbase.com/ -> API
# -----------------------------------------------------------
COINBASE_API_KEY=your_coinbase_org_id_here
COINBASE_SECRET_KEY="-----BEGIN EC PRIVATE KEY-----
your_private_key_here
-----END EC PRIVATE KEY-----"

# -----------------------------------------------------------
# CryptoPanic News API (optional but recommended for sentiment)
# Free tier available at: https://cryptopanic.com/developers/api/
# -----------------------------------------------------------
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# -----------------------------------------------------------
# Reddit API (optional — for sentiment collection)
# Create an app at: https://www.reddit.com/prefs/apps
# -----------------------------------------------------------
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=crypto-oracle:v1.0 (by /u/yourusername)

# -----------------------------------------------------------
# Live Trading Safety Gate
# Must be exactly 'true' (lowercase) to place real orders.
# Leave as 'false' for paper trading and dry-run mode.
# -----------------------------------------------------------
LIVE_TRADING_ENABLED=false

# -----------------------------------------------------------
# Live Trader Tuning (optional — these are the defaults)
# -----------------------------------------------------------
MAX_SLIPPAGE_PCT=0.01          # Abort tracking if fill deviates >1% from expected
POLL_INTERVAL_SECONDS=30       # How often to check SL/TP (seconds)
